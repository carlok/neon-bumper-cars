{
  "name": "neon-survival-bumper-cars",
  "version": "1.1.12",
  "description": "Multiplayer WebSocket bumper cars game with mobile controllers",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testPathPattern=test/",
    "test:coverage": "jest --testPathPattern=test/ --coverage"
  },
  "jest": {
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"],
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  }
}
