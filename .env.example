# Copy to `.env` for `podman compose up` (default production service).
# Never commit `.env`.

PORT=3000
NODE_ENV=production

# Required in production: strong secret (not demo123, not empty).
ADMIN_PASSWORD=change-me-to-a-long-random-secret

# Visible arena columns across the projector view (40 = full arena width).
DISPLAY_ARENA_COLUMNS=40
